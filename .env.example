# AISES - Çevre Değişkenleri Örneği (.env)
# Bu dosyayı .env.local olarak kopyalayıp kendi anahtarlarınızı ekleyin.

# --- SUPABASE (Veritabanı ve Depolama) ---
# Supabase Dashboard -> Project Settings -> API kısmından alabilirsiniz.
NEXT_PUBLIC_SUPABASE_URL=https://proje-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=buraya-anon-key-gelecek

# Supabase Dashboard -> Project Settings -> API -> service_role (Gizli anahtar)
# Önemli: Bu anahtar sadece sunucu tarafında (API Routes) çalışır.
SUPABASE_SERVICE_ROLE_KEY=buraya-service-role-key-gelecek


# --- GOOGLE GEMINI (Yapay Zeka Söz Yazımı) ---
# https://aistudio.google.com/app/apikey adresinden ücretsiz alabilirsiniz.
GEMINI_API_KEY=buraya-gemini-api-key-gelecek


# --- REPLICATE (MusicGen - Müzik Üretimi) ---
# https://replicate.com/account/api-tokens adresinden alabilirsiniz.
REPLICATE_API_TOKEN=buraya-replicate-token-gelecek


# --- NEXTAUTH (Giriş Sistemi - Opsiyonel) ---
# Rastgele bir dize oluşturun (örn: openssl rand -base64 32)
NEXTAUTH_SECRET=herhangi-bir-gizli-sifre
NEXTAUTH_URL=http://localhost:3000
